{
  "name": "@ruvector/sdk",
  "version": "0.0.0-m5",
  "description": "RuVector SDK — task-first archetypes over upstream ruvector. M5 surface freeze (types only, no implementation).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./advanced": {
      "import": "./dist/advanced/index.js",
      "types": "./dist/advanced/index.d.ts"
    }
  },
  "bin": {
    "sdk": "./bin/sdk.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "verify": "tsc --noEmit && tsc --noEmit -p examples/tsconfig.json"
  },
  "engines": {
    "node": ">= 18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.5.0"
  },
  "license": "MIT",
  "dependencies": {
    "@ruvector/graph-node": "^2.0.3",
    "@ruvector/graph-wasm": "^2.0.2",
    "@ruvector/ruvllm": "^2.5.4",
    "@ruvector/ruvllm-darwin-arm64": "^2.0.1",
    "@ruvector/ruvllm-wasm": "^2.0.0",
    "@ruvector/sona": "^0.1.6"
  }
}
